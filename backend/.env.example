# Interview Copilot Configuration
# Copy to .env and fill in your values

# AI Builder Space (speech-to-text, fallback)
IC_AI_BUILDER_TOKEN=
IC_AI_BUILDER_BASE_URL=https://space.ai-builders.com/backend/v1
IC_AI_BUILDER_CONFIDENCE_THRESHOLD=0.4
IC_AI_BUILDER_MIN_TEXT_LENGTH=3
# Set to true to reduce text loss from filtering (looser confidence/length thresholds)
IC_AI_BUILDER_FILTER_RELAXED=false
IC_AI_BUILDER_PROMPT=这是一段面试对话录音。请只转写说话内容，不要描述噪音、设备状态或环境。
IC_AI_BUILDER_TERMS=

# Volcano Engine BigModel ASR (primary, China-optimized)
# Set IC_STT_PROVIDER=volcengine to prefer Volcano when PCM is available
IC_STT_PROVIDER=auto
IC_VOLCENGINE_APP_ID=
IC_VOLCENGINE_ASR_TOKEN=

# LLM via OpenRouter (https://openrouter.ai/docs/quickstart)
OPENROUTER_LLM_API_KEY=
IC_LLM_BASE_URL=https://openrouter.ai/api/v1
IC_LLM_MODEL=deepseek/deepseek-chat-v3-0324

# Feishu (optional, for importing company values)
IC_FEISHU_APP_ID=
IC_FEISHU_APP_SECRET=

# GitHub (optional, for importing project context from private repos)
IC_GITHUB_TOKEN=

# Database (default: SQLite)
IC_DATABASE_URL=sqlite+aiosqlite:///./interview_copilot.db

# Debug mode
IC_DEBUG=false
